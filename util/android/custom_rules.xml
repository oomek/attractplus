<?xml version="1.0" encoding="UTF-8"?>
<project>
    <target name="-pre-compile">

        <!-- copy core files to assets -->
        <property name="core.dir" location="../../core" />
        <echo message="Copying '${core.dir}' to assets" />

        <copy todir="assets">
         <fileset dir="../../core" />
        </copy>

        <!-- create manifest of copied core files -->
        <path id="example.path">
         <fileset dir="../../core" />
        </path>

        <!-- Format path -->
        <pathconvert pathsep="${line.separator}" property="echo.path.compile" refid="example.path">
         <map from="${core.dir}/" to="" />
        </pathconvert>

        <echo file="assets/manifest.txt">${echo.path.compile}${line.separator}</echo>
    </target>
</project>
